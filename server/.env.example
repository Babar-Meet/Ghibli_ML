PORT=8787
CLIENT_ORIGIN=*
PUBLIC_BASE_URL=http://localhost:8787
MAX_UPLOAD_MB=10

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=llava:13b
OLLAMA_IMAGE_MODEL=
OLLAMA_TIMEOUT_MS=90000
OLLAMA_STARTUP_CHECK=true
OLLAMA_AUTO_PULL=true
OLLAMA_PULL_OPTIONAL_MODELS=false
REQUIRE_AI_GENERATION=false
IMAGE_BACKEND=auto

COMFYUI_ENABLED=true
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_CHECKPOINT=
COMFYUI_TIMEOUT_MS=240000
COMFYUI_POLL_INTERVAL_MS=1200
COMFYUI_STEPS=20
COMFYUI_CFG=7
COMFYUI_DENOISE=0.55
# LoRA for Ghibli style (optional - leave empty to disable)
COMFYUI_LORA=
COMFYUI_LORA_STRENGTH=0.8
# Prompt template for Ghibli style (use {prompt} placeholder for user input)
COMFYUI_PROMPT_TEMPLATE=<lora:giblylast:0.8>, {prompt}, studio ghibli style, soft lighting, anime, hand drawn, watercolor, beautiful young character, clean art, high quality
# Negative prompt to avoid common issues
COMFYUI_NEGATIVE_PROMPT=deformed, distorted face, different person, bad anatomy, extra features, unrealistic eyes, old, aged, ugly, low quality, blurry, photo, realistic, hyperrealistic, 3d render, cg, cartoon, bad quality

GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
GOOGLE_DRIVE_ORIGINAL_FOLDER_ID=
GOOGLE_DRIVE_GENERATED_FOLDER_ID=
GOOGLE_DRIVE_MAKE_PUBLIC=true

COLLEGE_LOGO_PATH=../client/assets/college-logo.svg
WATERMARK_SHOW_LABEL=true
